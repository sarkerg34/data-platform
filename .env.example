# GCP project + data bucket
GCP_PROJECT=data-engineering-494500
GCS_BUCKET=gourab-github-velocity-dev

# Local dev runs application code as the pipeline writer SA via impersonation.
# Base identity is your `gcloud auth application-default login` credentials.
# The owner account needs roles/iam.serviceAccountTokenCreator on the SA;
# the IAM module grants this when `impersonators` includes your principal.
GOOGLE_IMPERSONATE_SERVICE_ACCOUNT=dagster-writer-dev@data-engineering-494500.iam.gserviceaccount.com

# Cross-repo wiring — Dagster runs dbt against the sibling analytics-engineering repo
DBT_PROJECT_DIR=../analytics-engineering

# Secret Manager *resource path* for the GitHub PAT.
# This is a path, NOT a value. Application code resolves it at runtime via the
# Secret Manager API (using the impersonated writer SA). Nothing secret on disk.
# Rotate by `gcloud secrets versions add github-pat-dev --data-file=-`.
GITHUB_PAT_SECRET=projects/data-engineering-494500/secrets/github-pat-dev/versions/latest
